---
import ReportLayout from '../layouts/ReportLayout.astro';
import HeroDashboard from '../components/HeroDashboard.astro';
import InsightCard from '../components/InsightCard.astro';
import { getPartOrder, getSectionsByPart } from '../scripts/parse-report';
import { evidenceSections } from '../data/evidence';

const parts = getPartOrder();
const sectionsByPart = getSectionsByPart();

const partColors: Record<number, string> = {
  1: 'border-blue-200 bg-blue-50/30',
  2: 'border-emerald-200 bg-emerald-50/30',
  3: 'border-purple-200 bg-purple-50/30',
  4: 'border-amber-200 bg-amber-50/30',
  5: 'border-cyan-200 bg-cyan-50/30',
  6: 'border-rose-200 bg-rose-50/30',
  7: 'border-orange-200 bg-orange-50/30',
  8: 'border-slate-200 bg-slate-50/30',
  9: 'border-indigo-200 bg-indigo-50/30',
  10: 'border-teal-200 bg-teal-50/30',
  11: 'border-navy-200 bg-navy-50/30',
};
---

<ReportLayout title="Dashboard">
  <!-- Hero header -->
  <div class="mb-10">
    <h1 class="text-3xl sm:text-4xl font-extrabold text-navy-900 tracking-tight">
      Italian Factoring & Trade Finance
    </h1>
    <p class="mt-2 text-navy-500 text-lg">
      Comprehensive market intelligence — 62 sections across 10 parts
    </p>
    <div class="mt-3 flex items-center gap-3 text-sm text-navy-400">
      <span class="inline-flex items-center gap-1.5 bg-navy-50 px-3 py-1 rounded-full">
        <span class="w-2 h-2 bg-emerald-500 rounded-full"></span>
        Report compiled March 2026
      </span>
    </div>
  </div>

  <!-- Key Stats Dashboard -->
  <HeroDashboard />

  <!-- Key Evidence Sections -->
  {evidenceSections.map(section => (
    <section class={`${section.bg} rounded-2xl p-6 sm:p-8 mb-8`}>
      <h2 class="text-xl font-extrabold text-navy-900 tracking-tight">{section.title}</h2>
      <p class="text-sm text-navy-500 mt-1 mb-5">{section.subtitle}</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {section.items.map(item => (
          <InsightCard
            headline={item.headline}
            data={item.data}
            detail={item.detail}
            slug={item.slug}
            sectionLabel={item.sectionLabel}
            accent={section.accent}
          />
        ))}
      </div>
    </section>
  ))}

  <!-- Jump to Part pills -->
  <div class="flex flex-wrap gap-2 mb-10">
    {parts.map(p => (
      <a
        href={`#part-${p.partNumber}`}
        class="text-xs font-medium text-navy-600 bg-navy-50 hover:bg-navy-100 px-3 py-1.5 rounded-full transition-colors"
      >
        {p.part}
      </a>
    ))}
  </div>

  <!-- Part grid with section links -->
  <div class="space-y-6">
    {parts.map(p => {
      const sections = sectionsByPart.get(p.part) || [];
      const colorClass = partColors[p.partNumber] || 'border-navy-200 bg-navy-50/30';
      return (
        <section id={`part-${p.partNumber}`} class={`rounded-xl border ${colorClass} p-6`}>
          <h2 class="text-lg font-bold text-navy-900 mb-1">{p.part}</h2>
          <p class="text-sm text-navy-500 mb-4">{p.partTitle}</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1">
            {sections.map(s => {
              const displayTitle = s.isAppendix ? s.title : `${s.id}. ${s.title}`;
              return (
                <a
                  href={`/${s.slug}`}
                  class="text-sm text-navy-700 hover:text-blue-700 py-1.5 transition-colors flex items-start gap-1.5"
                >
                  <span class="text-navy-300 mt-0.5 flex-shrink-0">&rarr;</span>
                  <span>{displayTitle}</span>
                </a>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</ReportLayout>

---
import ReportLayout from '../layouts/ReportLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionNav from '../components/SectionNav.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { parseReport } from '../scripts/parse-report';
import { marked } from 'marked';

export function getStaticPaths() {
  const sections = parseReport();
  return sections.map((section, index) => {
    const prev = index > 0 ? sections[index - 1] : null;
    const next = index < sections.length - 1 ? sections[index + 1] : null;
    return {
      params: { slug: section.slug },
      props: { section, prev, next },
    };
  });
}

const { section, prev, next } = Astro.props;

// Configure marked for GFM tables
marked.setOptions({ gfm: true, breaks: false });

// Custom renderer for marked v15+ (token-based API)
const renderer = new marked.Renderer();

// Add IDs to h3/h4 headings for scroll-spy
renderer.heading = function(token: { text: string; depth: number; tokens: any[] }) {
  const text = this.parser.parseInline(token.tokens);
  const cleanText = text.replace(/<[^>]+>/g, '');
  const id = cleanText.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  return `<h${token.depth} id="${id}">${text}</h${token.depth}>\n`;
};

// Wrap tables for horizontal scroll
renderer.table = function(token: { header: any[]; rows: any[] }) {
  let headerCells = '';
  for (const cell of token.header) {
    const content = this.parser.parseInline(cell.tokens);
    const align = cell.align ? ` style="text-align:${cell.align}"` : '';
    headerCells += `<th${align}>${content}</th>`;
  }

  let bodyRows = '';
  for (const row of token.rows) {
    let cells = '';
    for (const cell of row) {
      const content = this.parser.parseInline(cell.tokens);
      const align = cell.align ? ` style="text-align:${cell.align}"` : '';
      cells += `<td${align}>${content}</td>`;
    }
    bodyRows += `<tr>${cells}</tr>`;
  }

  return `<div class="table-wrapper"><table><thead><tr>${headerCells}</tr></thead><tbody>${bodyRows}</tbody></table></div>\n`;
};

const html = await marked(section.markdown, { renderer });

const pageTitle = section.isAppendix ? section.title : `${section.id}. ${section.title}`;
---

<ReportLayout title={pageTitle} currentSlug={section.slug}>
  <Breadcrumb part={section.part} partTitle={section.partTitle} sectionTitle={pageTitle} />

  <article class="prose prose-navy max-w-none">
    <h1 class="text-2xl sm:text-3xl font-extrabold text-navy-900 tracking-tight mb-8">
      {pageTitle}
    </h1>
    <Fragment set:html={html} />
  </article>

  <SectionNav
    prevSlug={prev?.slug}
    prevTitle={prev ? (prev.isAppendix ? prev.title : `${prev.id}. ${prev.title}`) : undefined}
    nextSlug={next?.slug}
    nextTitle={next ? (next.isAppendix ? next.title : `${next.id}. ${next.title}`) : undefined}
  />

  <TableOfContents headings={section.headings} />
</ReportLayout>

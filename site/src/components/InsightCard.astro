---
interface Props {
  headline: string;
  data: string;
  detail: string;
  slug: string;
  sectionLabel: string;
  accent: 'blue' | 'rose' | 'emerald';
}

const { headline, data, detail, slug, sectionLabel, accent } = Astro.props;

const accentMap = {
  blue:    { border: 'border-l-blue-500',    text: 'text-blue-700',    badge: 'bg-blue-50 text-blue-600' },
  rose:    { border: 'border-l-rose-500',    text: 'text-rose-700',    badge: 'bg-rose-50 text-rose-600' },
  emerald: { border: 'border-l-emerald-500', text: 'text-emerald-700', badge: 'bg-emerald-50 text-emerald-600' },
};

const c = accentMap[accent];
---

<a
  href={`/${slug}`}
  class={`block rounded-lg border border-navy-100 bg-white ${c.border} border-l-4 p-5 transition-all hover:shadow-md hover:-translate-y-0.5 group`}
>
  <div class="flex items-start justify-between gap-3 mb-2">
    <span class="text-xs font-semibold text-navy-500 uppercase tracking-wide">{headline}</span>
    <span class={`text-[10px] font-medium px-2 py-0.5 rounded-full ${c.badge} flex-shrink-0`}>{sectionLabel}</span>
  </div>
  <div class={`text-2xl font-extrabold ${c.text} tracking-tight mb-1.5`}>{data}</div>
  <p class="text-sm text-navy-600 leading-relaxed">{detail}</p>
  <span class={`inline-block mt-3 text-xs font-medium ${c.text} opacity-0 group-hover:opacity-100 transition-opacity`}>
    Read more &rarr;
  </span>
</a>

---
interface Props {
  part: string;
  partTitle: string;
  sectionTitle: string;
}

const { part, partTitle, sectionTitle } = Astro.props;
---

<nav class="flex items-center gap-2 text-sm text-navy-500 mb-6" aria-label="Breadcrumb">
  <a href="/" class="hover:text-navy-800 transition-colors">Home</a>
  <span class="text-navy-300">/</span>
  <span class="text-navy-600 font-medium">{part}</span>
  <span class="text-navy-300">/</span>
  <span class="text-navy-800 font-medium truncate">{sectionTitle}</span>
</nav>

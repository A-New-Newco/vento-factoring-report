---
import StatCard from './StatCard.astro';
import { heroStats } from '../data/hero-stats';
---

<section class="mb-12">
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {heroStats.map(stat => (
      <StatCard
        value={stat.value}
        label={stat.label}
        detail={stat.detail}
        color={stat.color}
      />
    ))}
  </div>
</section>
